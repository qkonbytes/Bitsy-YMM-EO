{% schema %}
{
  "name": "YMM Results",
  "target": "section",
  "settings": [
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#e63e2f"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Color",
      "default": "#111111"
    }
  ]
}
{% endschema %}

<div class="bymm-wrap">

  <!-- Header -->
  <div class="bymm-header">
    <div class="bymm-header-left">
      <span class="bymm-label">Results for</span>
      <h1 class="bymm-title" id="bymm-title">Loading...</h1>
    </div>
    <a href="/" class="bymm-change">Change vehicle</a>
  </div>

  <!-- Loading -->
  <div id="bymm-loading" class="bymm-loading">
    <div class="bymm-spinner"></div>
    <p>Finding parts for your vehicle...</p>
  </div>

  <!-- Count bar -->
  <div id="bymm-sort-bar" class="bymm-sort-bar" style="display:none;">
    <span class="bymm-count" id="bymm-count"></span>
    <select class="bymm-sort-select" id="bymm-sort">
      <option value="default">Sort: Featured</option>
      <option value="price-asc">Price: Low to High</option>
      <option value="price-desc">Price: High to Low</option>
      <option value="title-asc">Name: A–Z</option>
      <option value="title-desc">Name: Z–A</option>
    </select>
  </div>

  <!-- Product Grid -->
  <div id="bymm-grid" class="bymm-grid" style="display:none;"></div>

  <!-- Empty State -->
  <div id="bymm-empty" class="bymm-empty" style="display:none;">
    <p>No parts found for your vehicle.</p>
    <a href="/" class="bymm-back-btn">Search Again</a>
  </div>

  <!-- Universal Products Section -->
  <div class="bymm-universal" id="bymm-universal" style="display:none;">
    <div class="bymm-universal-header">
      <h2 class="bymm-universal-title">Universal Fit Parts</h2>
      <p class="bymm-universal-sub">These parts are compatible with all vehicles</p>
    </div>
    <div id="bymm-universal-grid" class="bymm-grid"></div>
  </div>

</div>

<style>
  .bymm-wrap {
    max-width: 1280px;
    margin: 0 auto;
    padding: 1.5rem 1rem 3rem;
    font-family: inherit;
  }
  .bymm-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding-bottom: 1rem;
    border-bottom: 2px solid #111;
    margin-bottom: 1.5rem;
  }
  .bymm-label {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #999;
    margin-bottom: 0.2rem;
  }
  .bymm-title {
    font-size: 1.6rem;
    font-weight: 800;
    margin: 0;
  }
  .bymm-change {
    font-size: 0.85rem;
    color: {{ block.settings.accent_color }};
    text-decoration: underline;
    white-space: nowrap;
    margin-left: 1rem;
  }
  .bymm-loading {
    text-align: center;
    padding: 4rem 2rem;
    color: #999;
  }
  .bymm-spinner {
    width: 32px;
    height: 32px;
    border: 3px solid #eee;
    border-top-color: #111;
    border-radius: 50%;
    animation: bymm-spin 0.7s linear infinite;
    margin: 0 auto 1rem;
  }
  @keyframes bymm-spin { to { transform: rotate(360deg); } }
  .bymm-sort-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.25rem;
  }
  .bymm-count {
    font-size: 0.85rem;
    color: #666;
  }
  .bymm-sort-select {
    padding: 0.4rem 0.75rem;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 0.85rem;
    background: white;
    cursor: pointer;
  }
  .bymm-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    margin-bottom: 2rem;
  }
  .bymm-card {
    border: 1px solid #e5e5e5;
    border-radius: 6px;
    overflow: hidden;
    transition: box-shadow 0.2s, transform 0.2s;
    background: white;
  }
  .bymm-card:hover {
    box-shadow: 0 6px 20px rgba(0,0,0,0.09);
    transform: translateY(-2px);
  }
  .bymm-card-img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    background: #f7f7f7;
    display: block;
  }
  .bymm-card-no-img {
    width: 100%;
    aspect-ratio: 1;
    background: #f7f7f7;
  }
  .bymm-card-body {
    padding: 0.75rem;
  }
  .bymm-card-title {
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 0.4rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.3;
  }
  .bymm-card-price {
    font-size: 0.95rem;
    font-weight: 700;
    color: #111;
    margin-bottom: 0.65rem;
  }
  .bymm-card-btn {
    display: block;
    width: 100%;
    padding: 0.55rem;
    text-align: center;
    color: white;
    background: {{ block.settings.button_color }};
    border: none;
    border-radius: 4px;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .bymm-card-btn:hover { opacity: 0.85; }
  .bymm-empty {
    text-align: center;
    padding: 4rem 2rem;
    color: #999;
  }
  .bymm-back-btn {
    display: inline-block;
    margin-top: 1rem;
    padding: 0.65rem 1.5rem;
    background: #111;
    color: white;
    border-radius: 4px;
    text-decoration: none;
    font-size: 0.9rem;
  }
  .bymm-universal {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 2px solid #f0f0f0;
  }
  .bymm-universal-header {
    margin-bottom: 1.5rem;
  }
  .bymm-universal-title {
    font-size: 1.3rem;
    font-weight: 800;
    margin: 0 0 0.3rem;
  }
  .bymm-universal-sub {
    font-size: 0.85rem;
    color: #999;
    margin: 0;
  }
  @media (max-width: 768px) {
    .bymm-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .bymm-title { font-size: 1.2rem; }
  }
</style>

<script>
  const SUPABASE_URL = 'https://mpvhnycxwntslepogfuc.supabase.co';
  const SUPABASE_ANON_KEY = 'sb_publishable_shCSxRk-MJJDWblwk9IJwQ_iCwrl3CT';

  const params = new URLSearchParams(window.location.search);
  const SELECTED_MAKE  = params.get('make');
  const SELECTED_MODEL = params.get('model');
  const SELECTED_YEAR  = params.get('year');

  const HEADERS = {
    apikey: SUPABASE_ANON_KEY,
    Authorization: `Bearer ${SUPABASE_ANON_KEY}`,
    'Content-Type': 'application/json'
  };

  let allProducts = [];
  let sortOrder = 'default';

  const titleEl    = document.getElementById('bymm-title');
  const loadingEl  = document.getElementById('bymm-loading');
  const gridEl     = document.getElementById('bymm-grid');
  const emptyEl    = document.getElementById('bymm-empty');
  const countEl    = document.getElementById('bymm-count');
  const sortBarEl  = document.getElementById('bymm-sort-bar');
  const universalEl = document.getElementById('bymm-universal');
  const uniGridEl  = document.getElementById('bymm-universal-grid');

  function buildCard(p) {
    const img   = p.image_url || '';
    const title = p.product_title || 'Product';
    const price = p.price ? 'R ' + parseFloat(p.price).toFixed(2) : '';
    const handle = p.product_handle || '';

    return '<div class="bymm-card">' +
      (img
        ? '<img class="bymm-card-img" src="' + img + '" alt="' + title + '" loading="lazy">'
        : '<div class="bymm-card-no-img"></div>') +
      '<div class="bymm-card-body">' +
        '<p class="bymm-card-title">' + title + '</p>' +
        (price ? '<p class="bymm-card-price">' + price + '</p>' : '') +
        (handle ? '<a href="/products/' + handle + '" class="bymm-card-btn">View Product</a>' : '') +
      '</div></div>';
  }

  function sortProducts(products) {
    const sorted = [...products];
    if (sortOrder === 'price-asc') {
      sorted.sort((a, b) => parseFloat(a.price || 0) - parseFloat(b.price || 0));
    } else if (sortOrder === 'price-desc') {
      sorted.sort((a, b) => parseFloat(b.price || 0) - parseFloat(a.price || 0));
    } else if (sortOrder === 'title-asc') {
      sorted.sort((a, b) => (a.product_title || '').localeCompare(b.product_title || ''));
    } else if (sortOrder === 'title-desc') {
      sorted.sort((a, b) => (b.product_title || '').localeCompare(a.product_title || ''));
    }
    return sorted;
  }

  function renderGrid() {
    const sorted = sortProducts(allProducts);
    countEl.textContent = sorted.length + ' part(s) found';
    if (sorted.length === 0) {
      gridEl.style.display = 'none';
      sortBarEl.style.display = 'none';
      emptyEl.style.display = 'block';
    } else {
      gridEl.style.display = 'grid';
      sortBarEl.style.display = 'flex';
      emptyEl.style.display = 'none';
      gridEl.innerHTML = sorted.map(buildCard).join('');
    }
  }

  document.getElementById('bymm-sort').addEventListener('change', e => {
    sortOrder = e.target.value;
    renderGrid();
  });

  async function init() {
    if (!SELECTED_MAKE || !SELECTED_MODEL || !SELECTED_YEAR) {
      loadingEl.style.display = 'none';
      emptyEl.style.display = 'block';
      return;
    }

    titleEl.textContent = SELECTED_YEAR + ' ' + SELECTED_MAKE + ' ' + SELECTED_MODEL;

    try {
      // Fetch fitted and universal products in parallel
      const [fitRes, uniRes] = await Promise.all([
        fetch(`${SUPABASE_URL}/rest/v1/rpc/get_fitment_products`, {
          method: 'POST',
          headers: HEADERS,
          body: JSON.stringify({
            p_make: SELECTED_MAKE,
            p_model: SELECTED_MODEL,
            p_year: SELECTED_YEAR
          })
        }),
        fetch(`${SUPABASE_URL}/rest/v1/rpc/get_universal_products`, {
          method: 'POST',
          headers: HEADERS,
          body: '{}'
        })
      ]);

      const [fittedData, universalData] = await Promise.all([
        fitRes.json(),
        uniRes.json()
      ]);

      loadingEl.style.display = 'none';
      allProducts = fittedData || [];
      renderGrid();

      // Render universal section
      if (universalData && universalData.length > 0) {
        universalEl.style.display = 'block';
        uniGridEl.innerHTML = universalData.map(buildCard).join('');
      }

    } catch (err) {
      loadingEl.textContent = 'Failed to load results. Please try again.';
      console.error(err);
    }
  }

  init();
</script>