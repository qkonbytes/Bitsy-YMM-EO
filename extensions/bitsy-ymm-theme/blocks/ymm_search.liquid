{% schema %}
{
  "name": "YMM Search",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find Parts For Your Vehicle"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Color",
      "default": "#000000"
    }
  ]
}
{% endschema %}

<div class="bitsy-ymm-search" id="bitsy-ymm-search">
  <h2 class="bitsy-ymm-heading">{{ block.settings.heading }}</h2>

  <div class="bitsy-ymm-dropdowns">
    <div class="bitsy-ymm-field">
      <label for="bitsy-make">Make</label>
      <select id="bitsy-make" name="make">
        <option value="">Select Make</option>
      </select>
    </div>

    <div class="bitsy-ymm-field">
      <label for="bitsy-model">Model</label>
      <select id="bitsy-model" name="model" disabled>
        <option value="">Select Model</option>
      </select>
    </div>

    <div class="bitsy-ymm-field">
      <label for="bitsy-year">Year</label>
      <select id="bitsy-year" name="year" disabled>
        <option value="">Select Year</option>
      </select>
    </div>
  </div>

  <button
    id="bitsy-search-btn"
    class="bitsy-ymm-btn"
    style="background-color: {{ block.settings.button_color }};"
    disabled
  >
    Find Parts
  </button>
</div>

<style>
  .bitsy-ymm-search {
    padding: 2rem;
    max-width: 800px;
    margin: 0 auto;
  }
  .bitsy-ymm-heading {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    text-align: center;
  }
  .bitsy-ymm-dropdowns {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .bitsy-ymm-field {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 150px;
  }
  .bitsy-ymm-field label {
    font-size: 0.85rem;
    margin-bottom: 0.4rem;
    font-weight: 600;
  }
  .bitsy-ymm-field select {
    padding: 0.6rem;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-size: 1rem;
    background: white;
  }
  .bitsy-ymm-field select:disabled {
    background: #f5f5f5;
    cursor: not-allowed;
  }
  .bitsy-ymm-btn {
    width: 100%;
    padding: 0.85rem;
    color: white;
    border: none;
    border-radius: 4px;
    font-size: 1rem;
    cursor: pointer;
    margin-top: 0.5rem;
  }
  .bitsy-ymm-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>

<script src="{{ 'ymm.js' | asset_url }}" defer></script>